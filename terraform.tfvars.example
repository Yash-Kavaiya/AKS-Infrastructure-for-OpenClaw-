# Example Terraform variables file
# Copy this to terraform.tfvars and customize

resource_group_name = "openclaw-production-rg"
location            = "eastus"  # Options: eastus, westus2, westeurope, etc.
cluster_name        = "openclaw-aks-cluster"
environment         = "production"
kubernetes_version  = "1.28.0"  # Check latest: az aks get-versions --location eastus
enable_autoscaling  = true

# Team assignments for OpenClaw instances
team_assignments = {
  "team-alpha" = {
    name          = "alpha"
    namespace     = "openclaw-alpha"
    replicas      = 3
    node_selector = { "workload" = "openclaw-app" }
  }
  "team-beta" = {
    name          = "beta"
    namespace     = "openclaw-beta"
    replicas      = 3
    node_selector = { "workload" = "openclaw-app" }
  }
  "team-gamma" = {
    name          = "gamma"
    namespace     = "openclaw-gamma"
    replicas      = 2
    node_selector = { "workload" = "ai-processing" }
  }
  "team-delta" = {
    name          = "delta"
    namespace     = "openclaw-delta"
    replicas      = 2
    node_selector = { "workload" = "data-intensive" }
  }
}
